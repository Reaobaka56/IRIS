    %45 = const.i 64 : i64
    list_push %44, %45
    %47 = const.i 34 : i64
    list_push %44, %47
    %49 = const.i 25 : i64
    list_push %44, %49
    list_push %44, %9
    %53 = const.i 22 : i64
    list_push %44, %53
    %55 = const.i 11 : i64
    list_push %44, %55
    %57 = const.i 90 : i64
    list_push %44, %57
    %59 = list_len %44
    %60 = call @bubble_sort(%44, %59)
    %62 = const.str "["
    %72 = const.str ", "
    %80 = const.i 1 : i64
    br bb1(%62, %1)
  while_header1(%63 sorted_str, %64 i):
    %67 = list_len %44
    %68 = cmplt %64, %67
    condbr %68, bb2(), bb3(%63, %64)
  while_body2():
    %70 = cmpgt %64, %1
    condbr %70, bb4(), bb5()
  while_merge3(%65 sorted_str, %66 i):
    %82 = const.str "]"
    %83 = str_concat %65, %82
    %84 = const.str "sorted: "
    %85 = str_concat %84, %83
    print %85
    %87 = const.str "
=== Longest Common Subsequence ==="
    print %87
    %89 = const.str "ABCBDAB"
    %90 = const.str ""
    %91 = str_split %89, %90
    retain %91
    %92 = const.str "BDCABA"
    %93 = const.str ""
    %94 = str_split %92, %93
    retain %94
    %95 = list_len %91
    %96 = list_len %94
    %97 = call @lcs_len(%91, %95, %94, %96)
    %98 = const.str "LCS('ABCBDAB', 'BDCABA') = "
    %99 = to_str %97
    %100 = str_concat %98, %99
    print %100
    %102 = const.str "
=== Primes up to 50 ==="
    print %102
    %104 = const.str ""
    %110 = const.i 50 : i64
    %128 = const.i 1 : i64
    %118 = const.str " "
    br bb7(%104, %3)
  then4():
    %73 = str_concat %63, %72
    br bb6(%1, %73)
  else5():
    br bb6(%1, %63)
  merge6(%75 if_result, %76 sorted_str):
    %77 = list_get %44, %64
    %78 = to_str %77
    %79 = str_concat %76, %78
    %81 = add %64, %80
    br bb1(%79, %81)
  while_header7(%106 primes_str, %107 p):
    %111 = cmple %107, %110
    condbr %111, bb8(), bb9(%106, %107)
  while_body8():
    %112 = call @is_prime(%107)
    condbr %112, bb10(), bb11()
  while_merge9(%108 primes_str, %109 p):
    print %108
    release %2, List(Scalar(I64))
    release %44, List(Scalar(I64))
    release %91, List(Str)
    release %94, List(Str)
    return %1
  then10():
    %114 = str_len %106
    %116 = cmpgt %114, %1
    condbr %116, bb13(), bb14()
  else11():
    br bb12(%1, %106)
  merge12(%126 if_result, %127 primes_str):
    %129 = add %107, %128
    br bb7(%127, %129)
  then13():
    %119 = str_concat %106, %118
