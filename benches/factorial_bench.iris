// Benchmark: Factorial (iterative)
// Tests tight loop with arithmetic.

def factorial(n: i64) -> i64 {
    var result = 1
    var i = 2
    while i <= n {
        result = result * i;
        i = i + 1
    }
    result
}

def main() -> i64 {
    var sum = 0
    var i = 1
    while i <= 15 {
        sum = sum + factorial(i);
        i = i + 1
    }
    print(sum);
    0
}
