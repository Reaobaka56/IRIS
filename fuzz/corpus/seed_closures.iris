def apply(f: (i64) -> i64, x: i64) -> i64 { f(x) }
def main() -> i64 {
    val a = 10;
    val inc = |x: i64| x + a;
    val result = apply(inc, 5);
    val xs = [1, 2, 3];
    val doubled = list_map(xs, |x: i64| x * 2);
    val evens = list_filter(doubled, |x: i64| x > 3);
    val total = list_reduce(evens, 0, |acc: i64, x: i64| acc + x);
    print(result + total);
    0
}
