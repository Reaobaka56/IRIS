record Vec2 { x: f64, y: f64 }

impl Vec2 {
    def length(self: Vec2) -> f64 {
        sqrt(self.x * self.x + self.y * self.y)
    }
    def add(self: Vec2, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }
}

def main() -> i64 {
    val v1 = Vec2 { x: 3.0, y: 4.0 };
    val v2 = Vec2 { x: 1.0, y: 2.0 };
    val _v3 = v1.add(v2);
    val _len = v1.length();
    0
}
