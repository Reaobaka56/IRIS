// src/stdlib/testing.iris -- IRIS standard testing library

pub def assert_eq(actual: i64, expected: i64, msg: str) -> bool {
    if actual != expected {
        val exp_s = to_str(expected);
        val act_s = to_str(actual);
        print(concat(concat(concat(concat("FAIL: ", msg), concat(" — expected ", exp_s)), ", got "), act_s));
        false
    } else {
        true
    }
}

pub def assert_true(cond: bool, msg: str) -> bool {
    if !cond {
        print(concat("FAIL: ", msg));
        false
    } else {
        true
    }
}

pub def assert_false(cond: bool, msg: str) -> bool {
    if cond {
        print(concat("FAIL: ", msg));
        false
    } else {
        true
    }
}

pub def assert_str_eq(actual: str, expected: str, msg: str) -> bool {
    if actual != expected {
        print(concat(concat(concat(concat("FAIL: ", msg), concat(" — expected '", expected)), "', got '"), concat(actual, "'")));
        false
    } else {
        true
    }
}
