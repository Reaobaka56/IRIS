// src/stdlib/testing.iris -- IRIS standard testing library

/// Assert two i64 values are equal. Returns true on pass, false on fail.
pub def assert_eq(actual: i64, expected: i64, msg: str) -> bool {
    if actual != expected {
        val exp_s = to_str(expected);
        val act_s = to_str(actual);
        print(concat("FAIL [assert_eq] ", concat(msg, concat(" — expected ", concat(exp_s, concat(", got ", act_s))))));
        false
    } else {
        true
    }
}

/// Assert two f64 values are approximately equal (within tolerance).
pub def assert_approx_eq(actual: f64, expected: f64, tol: f64, msg: str) -> bool {
    val diff = abs(actual - expected);
    if diff > tol {
        val exp_s = to_str(expected);
        val act_s = to_str(actual);
        val tol_s = to_str(tol);
        print(concat("FAIL [assert_approx_eq] ", concat(msg, concat(" — expected ~", concat(exp_s, concat(" (tol=", concat(tol_s, concat("), got ", act_s))))))));
        false
    } else {
        true
    }
}

/// Assert two str values are equal.
pub def assert_str_eq(actual: str, expected: str, msg: str) -> bool {
    if actual != expected {
        print(concat("FAIL [assert_str_eq] ", concat(msg, concat(" — expected '", concat(expected, concat("', got '", concat(actual, "'")))))));
        false
    } else {
        true
    }
}

/// Assert a boolean is true.
pub def assert_true(cond: bool, msg: str) -> bool {
    if !cond {
        print(concat("FAIL [assert_true] ", msg));
        false
    } else {
        true
    }
}

/// Assert a boolean is false.
pub def assert_false(cond: bool, msg: str) -> bool {
    if cond {
        print(concat("FAIL [assert_false] ", msg));
        false
    } else {
        true
    }
}

/// Assert an option is some and unwrap it; panic if none.
pub def assert_some(opt: option<i64>, msg: str) -> i64 {
    if is_some(opt) {
        unwrap(opt)
    } else {
        print(concat("FAIL [assert_some] ", msg));
        panic(concat("expected some, got none: ", msg));
        0
    }
}

/// Assert an option is none.
pub def assert_none(opt: option<i64>, msg: str) -> bool {
    if is_some(opt) {
        print(concat("FAIL [assert_none] ", msg));
        false
    } else {
        true
    }
}

/// Assert a result<i64, str> is ok.
pub def assert_ok(res: result<i64, str>, msg: str) -> i64 {
    if is_ok(res) {
        unwrap(res)
    } else {
        print(concat("FAIL [assert_ok] ", msg));
        panic(concat("expected ok, got err: ", msg));
        0
    }
}

/// Assert a result<i64, str> is err.
pub def assert_err(res: result<i64, str>, msg: str) -> bool {
    if is_ok(res) {
        print(concat("FAIL [assert_err] ", msg));
        false
    } else {
        true
    }
}

/// Assert two i64 lists are equal element-by-element.
pub def assert_list_eq(actual: list<i64>, expected: list<i64>, msg: str) -> bool {
    val la = list_len(actual);
    val le = list_len(expected);
    if la != le {
        print(concat("FAIL [assert_list_eq] ", concat(msg, concat(" — length mismatch: got ", concat(to_str(la), concat(", expected ", to_str(le)))))));
        false
    } else {
        var ok = true;
        var i = 0;
        while i < la {
            val a = list_get(actual, i);
            val e = list_get(expected, i);
            if a != e {
                print(concat("FAIL [assert_list_eq] ", concat(msg, concat(" — index ", concat(to_str(i), concat(": got ", concat(to_str(a), concat(", expected ", to_str(e)))))))));
                ok = false;
            }
            i = i + 1;
        }
        ok
    }
}

/// Panic with a formatted failure message (unconditional fail).
pub def fail(msg: str) -> bool {
    print(concat("FAIL ", msg));
    panic(concat("test failed: ", msg));
    false
}
