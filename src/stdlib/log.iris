// src/stdlib/log.iris -- IRIS standard logging library

pub def info(msg: str) -> bool {
    print(concat("[INFO] ", msg));
    true
}

pub def warn(msg: str) -> bool {
    print(concat("[WARN] ", msg));
    true
}

pub def error(msg: str) -> bool {
    print(concat("[ERROR] ", msg));
    true
}

pub def debug(msg: str) -> bool {
    print(concat("[DEBUG] ", msg));
    true
}
