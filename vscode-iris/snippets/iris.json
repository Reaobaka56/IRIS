{
  "Function": {
    "prefix": "def",
    "body": ["def ${1:name}(${2:params}) -> ${3:type} {", "\t$0", "}"],
    "description": "Define a function"
  },
  "Public Function": {
    "prefix": "pub def",
    "body": ["pub def ${1:name}(${2:params}) -> ${3:type} {", "\t$0", "}"],
    "description": "Define a public function"
  },
  "Record": {
    "prefix": "record",
    "body": ["record ${1:Name} {", "\t${2:field}: ${3:type}", "}"],
    "description": "Define a record type"
  },
  "Choice": {
    "prefix": "choice",
    "body": ["choice ${1:Name} {", "\t${2:Variant1},", "\t${3:Variant2}", "}"],
    "description": "Define a choice (enum) type"
  },
  "Val binding": {
    "prefix": "val",
    "body": ["val ${1:name} = $0"],
    "description": "Immutable value binding"
  },
  "Var binding": {
    "prefix": "var",
    "body": ["var ${1:name} = $0"],
    "description": "Mutable variable binding"
  },
  "If-else": {
    "prefix": "if",
    "body": ["if ${1:cond} {", "\t$2", "} else {", "\t$3", "}"],
    "description": "If-else expression"
  },
  "While loop": {
    "prefix": "while",
    "body": ["while ${1:cond} {", "\t$0", "}"],
    "description": "While loop"
  },
  "For loop": {
    "prefix": "for",
    "body": ["for ${1:i} in ${2:0}..${3:n} {", "\t$0", "}"],
    "description": "For loop over range"
  },
  "When expression": {
    "prefix": "when",
    "body": [
      "when ${1:expr} {",
      "\tsome(${2:v}) => $3,",
      "\tnone => $4",
      "}"
    ],
    "description": "Pattern match with when"
  },
  "Main function": {
    "prefix": "main",
    "body": ["def main() -> i64 {", "\t$0", "\t0", "}"],
    "description": "Main entry point"
  },
  "Bring stdlib": {
    "prefix": "bring",
    "body": ["bring std.${1|math,string,fmt,json,csv,http,fs,path,time,set,queue,heap,kv,table,dataset,dataframe,ffi,crypto,os,testing,log,async,deque,sorted,bitset|}"],
    "description": "Import a stdlib module"
  },
  "List operations": {
    "prefix": "list",
    "body": [
      "var ${1:lst} = list()",
      "push(${1:lst}, ${2:value});"
    ],
    "description": "Create and populate a list"
  },
  "Option handling": {
    "prefix": "option",
    "body": [
      "val ${1:opt} = ${2:some(value)}",
      "if is_some(${1:opt}) {",
      "\tval ${3:v} = unwrap(${1:opt})",
      "\t$0",
      "}"
    ],
    "description": "Option type with is_some check"
  },
  "Result handling": {
    "prefix": "result",
    "body": [
      "val ${1:res} = ${2:ok(value)}",
      "if is_ok(${1:res}) {",
      "\tval ${3:v} = unwrap(${1:res})",
      "\t$0",
      "} else {",
      "\tpanic(\"error\")",
      "}"
    ],
    "description": "Result type with is_ok check"
  },
  "Print to_str": {
    "prefix": "print",
    "body": ["print(to_str(${1:value}));"],
    "description": "Print a value as string"
  },
  "Generic function": {
    "prefix": "defg",
    "body": ["def ${1:name}[${2:T}](${3:a}: ${2:T}) -> ${2:T} {", "\t$0", "}"],
    "description": "Define a generic function"
  },
  "FFI C call": {
    "prefix": "ffi",
    "body": [
      "bring std.ffi",
      "val ${1:lib} = ffi_open(\"${2:libname}\")",
      "val ${3:result} = ffi_call_i64(${1:lib}, \"${4:function}\", ${5:arg})",
      "ffi_close(${1:lib});"
    ],
    "description": "Open a C shared library and call a function via FFI"
  },
  "Python eval": {
    "prefix": "pyeval",
    "body": ["val ${1:result} = python_eval(\"${2:expression}\")"],
    "description": "Evaluate a Python expression and get the result"
  },
  "Python exec": {
    "prefix": "pyexec",
    "body": ["python_exec(\"${1:python_code}\");"],
    "description": "Execute Python code"
  },
  "Channel send/recv": {
    "prefix": "chan",
    "body": [
      "val ${1:ch} = channel()",
      "send(${1:ch}, ${2:value});",
      "val ${3:received} = recv(${1:ch})"
    ],
    "description": "Create a channel and send/receive a value"
  },
  "Spawn async": {
    "prefix": "spawn",
    "body": [
      "spawn {",
      "\t$0",
      "}"
    ],
    "description": "Spawn an asynchronous task"
  },
  "List map/filter": {
    "prefix": "listmap",
    "body": [
      "val ${1:mapped} = list_map(${2:lst}, |${3:x}| { ${4:x * 2} })",
      "val ${5:filtered} = list_filter(${2:lst}, |${3:x}| { ${6:x > 0} })"
    ],
    "description": "Map and filter a list with closures"
  },
  "Error handling": {
    "prefix": "trycatch",
    "body": [
      "val ${1:res} = ${2:ok(value)}",
      "when ${1:res} {",
      "\tok(${3:v}) => $4,",
      "\terr(${5:e}) => panic(to_str(${5:e}))",
      "}"
    ],
    "description": "Pattern-match on a result value"
  },
  "HTTP GET": {
    "prefix": "httpget",
    "body": [
      "bring std.http",
      "val ${1:response} = http_get(\"${2:https://api.example.com/data}\")",
      "print(${1:response});"
    ],
    "description": "Make an HTTP GET request"
  },
  "Constant": {
    "prefix": "const",
    "body": ["const ${1:NAME}: ${2:i64} = ${3:value}"],
    "description": "Define a constant"
  },
  "Deque operations": {
    "prefix": "deque",
    "body": [
      "val ${1:dq} = deque_new()",
      "deque_push_back(${1:dq}, ${2:value});",
      "val ${3:front} = deque_pop_front(${1:dq})"
    ],
    "description": "Create and use a double-ended queue"
  },
  "Test function": {
    "prefix": "test",
    "body": [
      "def test_${1:name}() -> bool {",
      "\tval ${2:result} = ${3:expr}",
      "\tassert(${2:result} == ${4:expected})",
      "\ttrue",
      "}"
    ],
    "description": "Define a test function"
  },
  "Doc comment": {
    "prefix": "///",
    "body": ["/// ${1:Description of the function}"],
    "description": "Documentation comment"
  },
  "Bring ML stdlib": {
    "prefix": "bring ml",
    "body": ["bring ml"],
    "description": "Import the IRIS ML standard library"
  },
  "MLP create and train": {
    "prefix": "mlp",
    "body": [
      "// Create MLP: [n_in, hidden, n_out]",
      "val ${1:model} = mlp_create(${2:2}, [${3:8}], ${4:1})",
      "val ${5:trained} = mlp_train(${1:model}, ${6:x_train}, ${7:y_train}, ${8:100}, ${9:0.01})",
      "val ${10:pred} = mlp_predict(${5:trained}, ${11:x_test})"
    ],
    "description": "Create, train, and use a multi-layer perceptron"
  },
  "Linear regression": {
    "prefix": "linreg",
    "body": [
      "val ${1:model} = linreg_train(${2:x_train}, ${3:y_train}, ${4:0.01}, ${5:100})",
      "val ${6:pred} = linreg_predict(${1:model}, ${7:x_test})",
      "val ${8:score} = r2_score(${3:y_train}, ${6:pred})",
      "print(concat(\"R2: \", to_str(${8:score})));"
    ],
    "description": "Train and evaluate a linear regression model"
  },
  "Logistic regression": {
    "prefix": "logreg",
    "body": [
      "val ${1:model} = logreg_train(${2:x_train}, ${3:y_train}, ${4:0.01}, ${5:100})",
      "val ${6:pred} = logreg_predict(${1:model}, ${7:x_test})",
      "val ${8:acc} = accuracy(${3:y_train}, ${6:pred})",
      "print(concat(\"Accuracy: \", to_str(${8:acc})));"
    ],
    "description": "Train and evaluate a logistic regression model"
  },
  "KNN predict": {
    "prefix": "knn",
    "body": [
      "val ${1:label} = knn_predict(${2:x_train}, ${3:y_train}, ${4:x_test}, ${5:3})"
    ],
    "description": "K-nearest neighbors prediction"
  },
  "K-means clustering": {
    "prefix": "kmeans",
    "body": [
      "val ${1:centroids} = kmeans_train(${2:data}, ${3:k}, ${4:100})"
    ],
    "description": "Train a K-means clustering model"
  },
  "Confusion matrix": {
    "prefix": "confusion",
    "body": [
      "val ${1:cm} = confusion_matrix_binary(${2:y_true}, ${3:y_pred})",
      "val ${4:p} = precision(${2:y_true}, ${3:y_pred})",
      "val ${5:r} = recall(${2:y_true}, ${3:y_pred})",
      "val ${6:f1} = f1_score(${2:y_true}, ${3:y_pred})",
      "print(concat(\"F1: \", to_str(${6:f1})));"
    ],
    "description": "Compute classification metrics"
  },
  "SGD update": {
    "prefix": "sgd",
    "body": [
      "val ${1:new_weights} = sgd_update(${2:weights}, ${3:grads}, ${4:0.01})"
    ],
    "description": "Stochastic gradient descent weight update"
  },
  "Adam update": {
    "prefix": "adam",
    "body": [
      "val ${1:result} = adam_update(${2:weights}, ${3:grads}, ${4:m1}, ${5:m2}, ${6:t}, ${7:0.001})"
    ],
    "description": "Adam optimizer weight update"
  },
  "Dense forward pass": {
    "prefix": "dense",
    "body": [
      "val ${1:out} = dense_forward(${2:input}, ${3:weights}, ${4:bias})"
    ],
    "description": "Dense (fully-connected) layer forward pass"
  },
  "Train/test split": {
    "prefix": "ttsplit",
    "body": [
      "val ${1:split} = train_test_split(${2:data}, ${3:labels}, ${4:0.8})",
      "val ${5:x_train} = list_get(${1:split}, 0)",
      "val ${6:x_test}  = list_get(${1:split}, 1)",
      "val ${7:y_train} = list_get(${1:split}, 2)",
      "val ${8:y_test}  = list_get(${1:split}, 3)"
    ],
    "description": "Split data into train and test sets"
  },
  "Normalize data": {
    "prefix": "normalize",
    "body": [
      "val ${1:normed} = min_max_normalize(${2:data})"
    ],
    "description": "Min-max normalize a list of values"
  },
  "TCP connect": {
    "prefix": "tcpconn",
    "body": [
      "val ${1:conn} = tcp_connect(\"${2:127.0.0.1}\", ${3:8080})",
      "tcp_write(${1:conn}, \"${4:hello}\");",
      "val ${5:resp} = tcp_read(${1:conn})",
      "tcp_close(${1:conn});"
    ],
    "description": "Connect to a TCP server, send, and receive"
  },
  "TCP server": {
    "prefix": "tcpserv",
    "body": [
      "val ${1:server} = tcp_listen(${2:8080})",
      "loop {",
      "\tval ${3:conn} = tcp_accept(${1:server})",
      "\tspawn {",
      "\t\tval ${4:msg} = tcp_read(${3:conn})",
      "\t\ttcp_write(${3:conn}, ${4:msg});",
      "\t\ttcp_close(${3:conn});",
      "\t}",
      "}"
    ],
    "description": "TCP server that accepts and handles connections"
  },
  "HTTP POST JSON": {
    "prefix": "httppost",
    "body": [
      "bring std.http",
      "val ${1:body} = json_stringify(${2:data})",
      "val ${3:resp} = http_post_json(\"${4:https://api.example.com/endpoint}\", ${1:body})",
      "print(${3:resp});"
    ],
    "description": "POST JSON to an HTTP endpoint"
  },
  "Par for loop": {
    "prefix": "parfor",
    "body": [
      "par for ${1:i} in ${2:0}..${3:n} {",
      "\t$0",
      "}"
    ],
    "description": "Parallel for loop"
  },
  "Async function": {
    "prefix": "async def",
    "body": [
      "async def ${1:name}(${2:params}) -> ${3:type} {",
      "\t$0",
      "}"
    ],
    "description": "Define an async function"
  },
  "Closure": {
    "prefix": "closure",
    "body": ["|${1:x}: ${2:i64}| { ${3:x * 2} }"],
    "description": "Lambda / closure expression"
  },
  "Tuple destructure": {
    "prefix": "tuple",
    "body": [
      "val ${1:t} = (${2:a}, ${3:b})",
      "val ${4:x} = ${1:t}.0",
      "val ${5:y} = ${1:t}.1"
    ],
    "description": "Create and destructure a tuple"
  }
}
